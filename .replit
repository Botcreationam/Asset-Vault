modules = ["nodejs-24", "postgresql-16"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.development]
EXPO_PUBLIC_DOMAIN = "313a1de7-7786-45a3-a57b-ae471f05c147-00-35whqx513ynb8.riker.replit.dev"

[userenv.shared]
ADMIN_EMAILS = "frankmwalu04@gmail.com"

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8082
externalPort = 3003

[[ports]]
localPort = 20808
externalPort = 3001

[[ports]]
localPort = 22689
externalPort = 3000

[[ports]]
localPort = 22690
externalPort = 3002

[[ports]]
localPort = 24158
externalPort = 80
